# Server Configuration
PORT=3001
HOST=0.0.0.0
# Set to 1 or a trusted proxy/CIDR only when deployed behind a reverse proxy that sends X-Forwarded-For.
TRUST_PROXY=false

# API Key Authentication (for external API - /api/send, /api/broadcast)
API_KEY=replace-with-a-long-random-api-key
API_SEND_RATE_LIMIT_PER_MINUTE=30

# Dashboard Authentication
DASHBOARD_USERNAME=replace-with-dashboard-username
DASHBOARD_PASSWORD=replace-with-a-long-random-dashboard-password
JWT_SECRET=replace-with-a-different-long-random-jwt-secret
DASHBOARD_BCRYPT_ROUNDS=12

# WhatsApp Configuration
# Delay between messages in milliseconds (to avoid spam detection)
MESSAGE_DELAY_MS=1000

# Anti-ban: Daily message limit (default: 500)
DAILY_MESSAGE_LIMIT=500

# Safety limits
MAX_MESSAGE_LENGTH=4096
MAX_BROADCAST_TARGETS=100

# Session storage path
AUTH_FOLDER=./auth

# WhatsApp Web / Puppeteer initialization resilience
WHATSAPP_INITIALIZE_RETRIES=2
WHATSAPP_INITIALIZE_RETRY_DELAY_MS=5000
WHATSAPP_AUTH_TIMEOUT_MS=120000
PUPPETEER_PROTOCOL_TIMEOUT_MS=180000
# Keep false when Docker is run with Chrome sandbox support, for example --cap-add=SYS_ADMIN.
# Set true only when the runtime cannot support Chrome sandboxing.
CHROME_NO_SANDBOX=false

# Message log content is redacted by default; set true only when operationally required.
LOG_MESSAGE_CONTENT=false

# Logging level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
